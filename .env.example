# LeanIX Environment Variables

# Connection
LEANIX_WORKSPACE=https://app.leanix.net

# Authentication (choose one method)
# Method 1: API Token (exchanges for bearer via client_credentials OAuth flow)
LEANIX_API_TOKEN=

# Method 2: Technical User Token (alternative env var name)
LEANIX_TOKEN=

# SSL Verification
SSL_VERIFY=True

# MCP Server Configuration
HOST=0.0.0.0
PORT=9606
TRANSPORT=stdio

# Debug
DEBUG=False
PYTHONUNBUFFERED=1
